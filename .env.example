# ---------------------------------------------------------------------------
# Sports Oracle — environment configuration. Copy to `.env` and fill in.
# Keyless providers (ESPN, TheSportsDB free) work without any keys.
# ---------------------------------------------------------------------------

# --- LLM (Anthropic / Claude) ---
ANTHROPIC_API_KEY=
MODEL_SYNTH=claude-opus-4-8
MODEL_ROUTER=claude-sonnet-4-6
MODEL_PREDICT=claude-opus-4-8

# --- Sports data providers (keyless ones work without these) ---
APISPORTS_KEY=                       # API-Football / API-Sports (free tier)
BALLDONTLIE_KEY=                     # NBA free tier
THESPORTSDB_KEY=3                    # '3' = free public test key
ESPN_BASE=https://site.api.espn.com  # keyless unofficial
PROVIDER_USER_AGENT=sports-oracle/0.1

# --- MCP ---
MCP_SPORTS_URL=http://mcp-sports:8765/mcp
MCP_TRANSPORT=streamable-http

# --- Postgres ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=sports_oracle
POSTGRES_USER=oracle
POSTGRES_PASSWORD=oracle
DATABASE_URL=postgresql+asyncpg://oracle:oracle@postgres:5432/sports_oracle

# --- Qdrant ---
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# --- RAG models (baked into image; names overridable) ---
EMBED_MODEL=BAAI/bge-small-en-v1.5
SPARSE_MODEL=prithivida/Splade_PP_en_v1
RERANK_MODEL=BAAI/bge-reranker-base
CACHE_SIM_THRESHOLD=0.92
# Inference device for local embeddings/reranker: cuda | cpu | auto
# 'auto' uses GPU when a CUDA device + onnxruntime-gpu are present, else CPU.
EMBED_DEVICE=auto
EMBED_BATCH_SIZE=64

# --- App ---
API_PORT=8000
WEB_ORIGIN=http://localhost:5173
LOG_LEVEL=info
NEWS_FEEDS=https://www.espn.com/espn/rss/news,https://feeds.bbci.co.uk/sport/rss.xml
